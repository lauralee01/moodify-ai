# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies (applies to both frontend and backend)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage

# Frontend (Next.js)
frontend/.next
frontend/out

# Backend (Node/Nest build output)
backend/dist
backend/build

# Production build (any app)
build

# Misc
.DS_Store
*.pem

# Private planning (do not expose in repo)
build-plan.md
docs

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env and secrets (both apps – never commit)
.env
.env.local
.env*.local
# Keep .env.example committed (safe template; no real keys)
!.env.example

# Vercel (if frontend is deployed via Vercel)
.vercel

# TypeScript
*.tsbuildinfo
